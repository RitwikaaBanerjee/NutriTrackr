# ============================================
# Hostel Nutrition Backend - Environment Config
# ============================================

# Server Port
PORT=5000

# MongoDB Connection URI (Atlas example)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hostel_nutrition?retryWrites=true&w=majority
# Firebase Admin SDK Credentials
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
# IMPORTANT: Wrap the private key in double quotes and keep the \n characters as-is
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Gemini API Key
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
